generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleCode {
  CR_OFFICER
  CR_MANAGER
  BRANCH_MANAGER
  ADMIN
  MGMT_READONLY
  CUSTOMER_PORTAL
}

enum ComplaintStatus {
  DRAFT
  SUBMITTED
  MANAGER_REVIEW
  BRANCH_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
  REOPENED
  REJECTED
}

enum ComplaintTransitionAction {
  SUBMIT
  ACCEPT_INTAKE
  REJECT_AS_INVALID
  APPROVE_AND_ROUTE
  SEND_BACK
  ASSIGN_INVESTIGATION
  RESOLVE_DIRECTLY
  REJECT_AFTER_REVIEW
  ADD_INVESTIGATION_UPDATE
  RESOLVE
  REJECT_AFTER_INVESTIGATION
  CLOSE
  REJECT_RESOLUTION
  REOPEN
  ROUTE_AGAIN
}

enum ComplaintTransitionRequestSource {
  STAFF_API
  CUSTOMER_PORTAL
  SYSTEM_JOB
  IMPORT
}

enum ComplaintSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ComplaintSource {
  STAFF
  PORTAL
  EMAIL
  PHONE
  DMS
}

enum ComplaintType {
  COMPLAINT
  INQUIRY
  SUGGESTION
  FEEDBACK
}

enum SlaStage {
  INTAKE
  MANAGER_REVIEW
  BRANCH_REVIEW
  INVESTIGATION
  RESOLUTION
  CLOSURE
}

enum WorkingCalendarMode {
  CALENDAR_HOURS
  ALWAYS_ON
}

enum SlaEventType {
  DEADLINE_SET
  WARNING
  BREACH
  PAUSED
  RESUMED
  RECALCULATED
}

enum CommentVisibility {
  INTERNAL
  PUBLIC
}

enum AttachmentScanStatus {
  PENDING
  CLEAN
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
}

enum NotificationStatus {
  QUEUED
  SENT
  FAILED
  CANCELLED
}

enum SurveyStatus {
  PENDING
  SUBMITTED
  EXPIRED
}

enum CompensationType {
  GIFT
  SERVICE_DISCOUNT
  REFUND_REQUEST
  REPLACEMENT
  GOODWILL
  OTHER
}

enum CompensationStatus {
  PROPOSED
  APPROVED
  REJECTED
  CANCELLED
}

enum PortalVerificationStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  WAITING
  DONE
}

enum TaskLinkEntityType {
  CUSTOMER
  VEHICLE
  COMPLAINT
  CASE
  DEAL
  EMPLOYEE
}

enum TaskParticipantRole {
  OWNER
  ASSIGNEE
  PARTICIPANT
  WATCHER
}

enum TaskVisibility {
  PARTICIPANTS
  BRANCH
  MANAGEMENT
}

enum TaskConfidentialityLevel {
  NORMAL
  CONFIDENTIAL
  RESTRICTED
}

enum DealStage {
  LEAD
  BOOKING
  PAYMENT
  FINANCE
  INSURANCE
  REGISTRATION
  PDI
  DELIVERY
  POST_DELIVERY
}

enum CaseType {
  CUSTOMER_COMPLAINT
  EMPLOYEE_GRIEVANCE
}

enum CaseConfidentialityLevel {
  NORMAL
  CONFIDENTIAL
}

enum CaseLifecycleStatus {
  DRAFT
  HR_REVIEW
  INVESTIGATION
  DECISION
  CLOSED
  APPEALED
}

enum CaseParticipantRole {
  OWNER
  PARTICIPANT
  ACCUSED
}

enum CapaActionStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum CaseLinkEntityType {
  CUSTOMER
  VEHICLE
  COMPLAINT
  DEAL
  EMPLOYEE
}

enum AuditEventType {
  AUTH
  USER_ADMIN
  COMPLAINT
  WORKFLOW
  COMMENT
  ATTACHMENT
  SLA
  NOTIFICATION
  REPORT
  CONFIG
  SECURITY
  TASK
}

model Branch {
  id             String          @id @default(cuid())
  code           String          @unique
  nameEn         String          @map("name_en")
  nameAr         String          @map("name_ar")
  timezone       String          @default("Asia/Riyadh")
  isActive       Boolean         @default(true) @map("is_active")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  users          User[]
  departments    Department[]
  complaints     Complaint[]
  slaPolicies    SlaPolicy[]
  auditLogs      AuditLog[]
  deals          Deal[]
  cases          Case[]

  @@map("branches")
}

model Department {
  id          String      @id @default(cuid())
  code        String      @unique
  nameEn      String      @map("name_en")
  nameAr      String      @map("name_ar")
  branchId    String?     @map("branch_id")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  branch      Branch?     @relation(fields: [branchId], references: [id])
  users       User[]
  complaints  Complaint[]
  slaPolicies SlaPolicy[]
  capaActions CapaAction[]

  @@index([branchId])
  @@map("departments")
}

model Role {
  id        String   @id @default(cuid())
  code      RoleCode @unique
  nameEn    String   @map("name_en")
  nameAr    String   @map("name_ar")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]

  @@map("roles")
}

model User {
  id                         String                   @id @default(cuid())
  email                      String                   @unique
  nameEn                     String                   @map("name_en")
  nameAr                     String                   @map("name_ar")
  passwordHash               String?                  @map("password_hash")
  roleId                     String                   @map("role_id")
  branchId                   String?                  @map("branch_id")
  departmentId               String?                  @map("department_id")
  isActive                   Boolean                  @default(true) @map("is_active")
  lockedAt                   DateTime?                @map("locked_at")
  lastLoginAt                DateTime?                @map("last_login_at")
  createdAt                  DateTime                 @default(now()) @map("created_at")
  updatedAt                  DateTime                 @updatedAt @map("updated_at")
  role                       Role                     @relation(fields: [roleId], references: [id])
  branch                     Branch?                  @relation(fields: [branchId], references: [id])
  department                 Department?              @relation(fields: [departmentId], references: [id])
  createdComplaints          Complaint[]              @relation("ComplaintCreatedBy")
  ownedComplaints            Complaint[]              @relation("ComplaintOwner")
  statusHistory              ComplaintStatusHistory[]
  comments                   Comment[]
  attachments                Attachment[]
  approvalsRequested         Approval[]               @relation("ApprovalRequestedBy")
  approvalsDecided           Approval[]               @relation("ApprovalDecidedBy")
  notifications              Notification[]           @relation("NotificationRecipient")
  surveys                    Survey[]
  compensationProposed       Compensation[]           @relation("CompensationProposedBy")
  compensationApproved       Compensation[]           @relation("CompensationApprovedBy")
  staffSessions              StaffSession[]
  passwordResetTokens        StaffPasswordResetToken[]
  auditLogs                  AuditLog[]               @relation("AuditActor")
  ownedTasks                 Task[]                   @relation("TaskOwner")
  assignedTasks              Task[]                   @relation("TaskAssignee")
  taskNextActions            Task[]                   @relation("TaskNextActionWho")
  taskParticipants           TaskParticipant[]
  taskStatusHistory          TaskStatusHistory[]
  ownedDeals                 Deal[]                   @relation("DealOwner")
  currentDealHandoffs        Deal[]                   @relation("DealCurrentHolder")
  ownedCases                 Case[]                   @relation("CaseOwner")
  ownedCapaActions           CapaAction[]             @relation("CapaActionOwner")
  caseParticipants           CaseParticipant[]
  caseRestrictedNotes        CaseRestrictedNote[]      @relation("CaseRestrictedNoteAuthor")

  @@index([roleId])
  @@index([branchId])
  @@index([departmentId])
  @@map("users")
}

model StaffSession {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  revokedAt   DateTime? @map("revoked_at")
  lastSeenAt  DateTime  @default(now()) @map("last_seen_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("staff_sessions")
}

model StaffPasswordResetToken {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("staff_password_reset_tokens")
}

model Category {
  id          String      @id @default(cuid())
  code        String      @unique
  nameEn      String      @map("name_en")
  nameAr      String      @map("name_ar")
  parentId    String?     @map("parent_id")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  parent      Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]  @relation("CategoryTree")
  complaints  Complaint[]
  slaPolicies SlaPolicy[]

  @@index([parentId])
  @@map("categories")
}

model Customer {
  id                  String               @id @default(cuid())
  nameEn              String               @map("name_en")
  nameAr              String               @map("name_ar")
  phone               String               @unique
  email               String?
  dmsCode             String?              @map("dms_code")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  vehicles            Vehicle[]
  complaints          Complaint[]
  surveys             Survey[]
  portalVerifications PortalVerification[]
  portalSessions      PortalSession[]
  notificationPreference CustomerNotificationPreference?

  @@map("customers")
}

model Vehicle {
  id         String      @id @default(cuid())
  vin        String      @unique
  plate      String
  makeEn     String      @map("make_en")
  modelEn    String      @map("model_en")
  year       Int
  customerId String?     @map("customer_id")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  customer   Customer?   @relation(fields: [customerId], references: [id])
  complaints Complaint[]

  @@index([customerId])
  @@map("vehicles")
}

model Complaint {
  id                   String                   @id @default(cuid())
  referenceNumber      String                   @unique @map("reference_number")
  status               ComplaintStatus          @default(DRAFT)
  type                 ComplaintType            @default(COMPLAINT)
  severity             ComplaintSeverity         @default(MEDIUM)
  source               ComplaintSource           @default(STAFF)
  subject              String                   @default("General complaint")
  branchId             String                   @map("branch_id")
  categoryId           String                   @map("category_id")
  customerId           String                   @map("customer_id")
  vehicleId            String?                  @map("vehicle_id")
  createdById          String?                  @map("created_by_id")
  ownerId              String?                  @map("owner_id")
  departmentId         String?                  @map("department_id")
  descriptionEn        String                   @map("description_en")
  descriptionAr        String?                  @map("description_ar")
  incidentAt           DateTime?                @map("incident_at")
  firstResponseAt      DateTime?                @map("first_response_at")
  resolvedAt           DateTime?                @map("resolved_at")
  closedAt             DateTime?                @map("closed_at")
  version              Int                      @default(1)
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")
  branch               Branch                   @relation(fields: [branchId], references: [id])
  category             Category                 @relation(fields: [categoryId], references: [id])
  customer             Customer                 @relation(fields: [customerId], references: [id])
  vehicle              Vehicle?                 @relation(fields: [vehicleId], references: [id])
  createdBy            User?                    @relation("ComplaintCreatedBy", fields: [createdById], references: [id])
  owner                User?                    @relation("ComplaintOwner", fields: [ownerId], references: [id])
  department           Department?              @relation(fields: [departmentId], references: [id])
  statusHistory        ComplaintStatusHistory[]
  approvals            Approval[]
  attachments          Attachment[]
  comments             Comment[]
  slaEvents            SlaEvent[]
  notifications        Notification[]
  surveys              Survey[]
  compensation         Compensation[]
  portalVerifications  PortalVerification[]
  portalSessions       PortalSession[]

  @@index([status])
  @@index([branchId, status])
  @@index([severity])
  @@index([createdAt])
  @@index([ownerId])
  @@index([referenceNumber])
  @@map("complaints")
}

model ComplaintStatusHistory {
  id            String          @id @default(cuid())
  complaintId   String          @map("complaint_id")
  fromStatus    ComplaintStatus? @map("from_status")
  toStatus      ComplaintStatus  @map("to_status")
  action        ComplaintTransitionAction?
  actorId       String?         @map("actor_id")
  actorRole     RoleCode?       @map("actor_role")
  requestSource ComplaintTransitionRequestSource? @map("request_source")
  reason        String?
  correlationId String?         @map("correlation_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  complaint     Complaint       @relation(fields: [complaintId], references: [id])
  actor         User?           @relation(fields: [actorId], references: [id])

  @@index([complaintId, createdAt])
  @@index([actorId])
  @@map("complaint_status_history")
}

model Approval {
  id            String         @id @default(cuid())
  complaintId   String         @map("complaint_id")
  requestedById String?        @map("requested_by_id")
  decidedById   String?        @map("decided_by_id")
  status        ApprovalStatus @default(PENDING)
  comment       String?
  requestedAt   DateTime       @default(now()) @map("requested_at")
  decidedAt     DateTime?      @map("decided_at")
  complaint     Complaint      @relation(fields: [complaintId], references: [id])
  requestedBy   User?          @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  decidedBy     User?          @relation("ApprovalDecidedBy", fields: [decidedById], references: [id])

  @@index([complaintId])
  @@index([status])
  @@map("approvals")
}

model Attachment {
  id             String               @id @default(cuid())
  complaintId    String               @map("complaint_id")
  uploadedById   String?              @map("uploaded_by_id")
  storageKey     String               @unique @map("storage_key")
  fileName       String               @map("file_name")
  contentType    String               @map("content_type")
  sizeBytes      Int                  @map("size_bytes")
  scanStatus     AttachmentScanStatus @default(PENDING) @map("scan_status")
  customerVisible Boolean             @default(false) @map("customer_visible")
  createdAt      DateTime             @default(now()) @map("created_at")
  complaint      Complaint            @relation(fields: [complaintId], references: [id])
  uploadedBy     User?                @relation(fields: [uploadedById], references: [id])

  @@index([complaintId])
  @@index([scanStatus])
  @@map("attachments")
}

model Comment {
  id            String            @id @default(cuid())
  complaintId   String            @map("complaint_id")
  authorId      String?           @map("author_id")
  body          String
  visibility    CommentVisibility @default(INTERNAL)
  editedAt      DateTime?         @map("edited_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  complaint     Complaint         @relation(fields: [complaintId], references: [id])
  author        User?             @relation(fields: [authorId], references: [id])

  @@index([complaintId, createdAt])
  @@index([visibility])
  @@map("comments")
}

model SlaPolicy {
  id                    String              @id @default(cuid())
  severity              ComplaintSeverity
  stage                 SlaStage
  branchId              String?             @map("branch_id")
  departmentId          String?             @map("department_id")
  categoryId            String?             @map("category_id")
  durationMinutes       Int                 @map("duration_minutes")
  warningPercent        Int                 @default(80) @map("warning_percent")
  branchTimezone        String              @default("Asia/Riyadh") @map("branch_timezone")
  workingCalendarMode   WorkingCalendarMode @default(ALWAYS_ON) @map("working_calendar_mode")
  pausePolicy           String              @default("NONE") @map("pause_policy")
  escalationLevel1      String              @map("escalation_level_1")
  escalationLevel2      String?             @map("escalation_level_2")
  escalationLevel3      String?             @map("escalation_level_3")
  totalTargetMinutes    Int?                @map("total_target_minutes")
  isActive              Boolean             @default(true) @map("is_active")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  branch                Branch?             @relation(fields: [branchId], references: [id])
  department            Department?         @relation(fields: [departmentId], references: [id])
  category              Category?           @relation(fields: [categoryId], references: [id])
  events                SlaEvent[]

  @@index([severity, stage])
  @@index([branchId])
  @@map("sla_policies")
}

model SlaEvent {
  id             String       @id @default(cuid())
  complaintId    String       @map("complaint_id")
  policyId       String?      @map("policy_id")
  type           SlaEventType
  stage          SlaStage
  dueAt          DateTime?    @map("due_at")
  occurredAt     DateTime     @default(now()) @map("occurred_at")
  idempotencyKey String       @unique @map("idempotency_key")
  complaint      Complaint    @relation(fields: [complaintId], references: [id])
  policy         SlaPolicy?   @relation(fields: [policyId], references: [id])

  @@index([complaintId, occurredAt])
  @@index([type])
  @@map("sla_events")
}

model Notification {
  id             String              @id @default(cuid())
  complaintId    String?             @map("complaint_id")
  recipientUserId String?            @map("recipient_user_id")
  channel        NotificationChannel
  status         NotificationStatus  @default(QUEUED)
  templateCode   String              @map("template_code")
  locale         String              @default("en")
  payload        Json
  provider       String?
  providerResult String?             @map("provider_result")
  queuedAt       DateTime            @default(now()) @map("queued_at")
  sentAt         DateTime?           @map("sent_at")
  failedAt       DateTime?           @map("failed_at")
  complaint      Complaint?          @relation(fields: [complaintId], references: [id])
  recipientUser  User?               @relation("NotificationRecipient", fields: [recipientUserId], references: [id])
  deliveryAttempts NotificationDeliveryAttempt[]

  @@index([complaintId])
  @@index([recipientUserId, status])
  @@map("notifications")
}

model NotificationDeliveryAttempt {
  id             String              @id @default(cuid())
  notificationId String              @map("notification_id")
  channel        NotificationChannel
  status         NotificationStatus
  provider       String?
  providerResult String?             @map("provider_result")
  failureReason  String?             @map("failure_reason")
  attemptedAt    DateTime            @default(now()) @map("attempted_at")
  notification   Notification        @relation(fields: [notificationId], references: [id])

  @@index([notificationId, attemptedAt])
  @@index([status])
  @@map("notification_delivery_attempts")
}

model CustomerNotificationPreference {
  id                 String               @id @default(cuid())
  customerId         String               @unique @map("customer_id")
  preferredChannel   NotificationChannel? @map("preferred_channel")
  smsQuietStart      String?              @map("sms_quiet_start")
  smsQuietEnd        String?              @map("sms_quiet_end")
  timezone           String?
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  customer           Customer             @relation(fields: [customerId], references: [id])

  @@map("customer_notification_preferences")
}

model NotificationTemplate {
  id          String              @id @default(cuid())
  code        String
  channel     NotificationChannel
  locale      String              @default("en")
  subject     String?
  body        String
  version     Int                 @default(1)
  versionNote String?             @map("version_note")
  isActive    Boolean             @default(true) @map("is_active")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@unique([code, channel, locale, version])
  @@index([code, channel, locale, isActive])
  @@map("notification_templates")
}

model Survey {
  id          String       @id @default(cuid())
  complaintId String       @map("complaint_id")
  customerId  String       @map("customer_id")
  userId      String?      @map("user_id")
  status      SurveyStatus @default(PENDING)
  rating      Int?
  comment     String?
  tokenHash   String       @map("token_hash")
  expiresAt   DateTime     @map("expires_at")
  submittedAt DateTime?    @map("submitted_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  complaint   Complaint    @relation(fields: [complaintId], references: [id])
  customer    Customer     @relation(fields: [customerId], references: [id])
  user        User?        @relation(fields: [userId], references: [id])

  @@index([complaintId])
  @@index([tokenHash])
  @@map("surveys")
}

model Compensation {
  id                 String             @id @default(cuid())
  complaintId        String             @map("complaint_id")
  type               CompensationType
  amount             Decimal?           @db.Decimal(12, 2)
  currency           String?
  description        String
  status             CompensationStatus @default(PROPOSED)
  proposedById       String?            @map("proposed_by_id")
  approvedById       String?            @map("approved_by_id")
  approvalComment    String?            @map("approval_comment")
  financeReference   String?            @map("finance_reference")
  customerVisible    Boolean            @default(false) @map("customer_visible")
  proposedAt         DateTime           @default(now()) @map("proposed_at")
  decidedAt          DateTime?          @map("decided_at")
  complaint          Complaint          @relation(fields: [complaintId], references: [id])
  proposedBy         User?              @relation("CompensationProposedBy", fields: [proposedById], references: [id])
  approvedBy         User?              @relation("CompensationApprovedBy", fields: [approvedById], references: [id])

  @@index([complaintId])
  @@index([status])
  @@map("compensation")
}

model PortalVerification {
  id            String                   @id @default(cuid())
  complaintId   String                   @map("complaint_id")
  customerId    String                   @map("customer_id")
  phone         String
  otpHash       String                   @map("otp_hash")
  status        PortalVerificationStatus @default(PENDING)
  attempts      Int                      @default(0)
  ipAddress     String?                  @map("ip_address")
  expiresAt     DateTime                 @map("expires_at")
  verifiedAt    DateTime?                @map("verified_at")
  createdAt     DateTime                 @default(now()) @map("created_at")
  complaint     Complaint                @relation(fields: [complaintId], references: [id])
  customer      Customer                 @relation(fields: [customerId], references: [id])

  @@index([complaintId, status])
  @@index([phone])
  @@map("portal_verifications")
}

model PortalSession {
  id           String     @id @default(cuid())
  complaintId  String     @map("complaint_id")
  customerId   String     @map("customer_id")
  sessionHash  String     @unique @map("session_hash")
  expiresAt    DateTime   @map("expires_at")
  lastSeenAt   DateTime   @default(now()) @map("last_seen_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  complaint    Complaint  @relation(fields: [complaintId], references: [id])
  customer     Customer   @relation(fields: [customerId], references: [id])

  @@index([complaintId])
  @@index([customerId])
  @@map("portal_sessions")
}

model Task {
  id                     String                   @id @default(cuid())
  title                  String
  ownerId                String                   @map("owner_id")
  assigneeId             String                   @map("assignee_id")
  dueAt                  DateTime                 @map("due_at")
  status                 TaskStatus               @default(OPEN)
  nextActionWhat         String?                  @map("next_action_what")
  nextActionWhoId        String?                  @map("next_action_who_id")
  nextActionWhen         DateTime?                @map("next_action_when")
  isCustomerPromise      Boolean                  @default(false) @map("is_customer_promise")
  visibility             TaskVisibility           @default(PARTICIPANTS)
  confidentialityLevel   TaskConfidentialityLevel @default(NORMAL) @map("confidentiality_level")
  createdAt              DateTime                 @default(now()) @map("created_at")
  updatedAt              DateTime                 @updatedAt @map("updated_at")
  owner                  User                     @relation("TaskOwner", fields: [ownerId], references: [id])
  assignee               User                     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  nextActionWho          User?                    @relation("TaskNextActionWho", fields: [nextActionWhoId], references: [id])
  links                  TaskLink[]
  participants           TaskParticipant[]
  statusHistory          TaskStatusHistory[]

  @@index([status, dueAt])
  @@index([ownerId])
  @@index([assigneeId])
  @@index([nextActionWhoId])
  @@map("tasks")
}

model TaskLink {
  id          String             @id @default(cuid())
  taskId      String             @map("task_id")
  entityType  TaskLinkEntityType @map("entity_type")
  entityId    String             @map("entity_id")
  createdAt   DateTime           @default(now()) @map("created_at")
  task        Task               @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("task_links")
}

model TaskParticipant {
  id        String              @id @default(cuid())
  taskId    String              @map("task_id")
  userId    String              @map("user_id")
  role      TaskParticipantRole @default(PARTICIPANT)
  createdAt DateTime            @default(now()) @map("created_at")
  task      Task                @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_participants")
}

model TaskStatusHistory {
  id            String      @id @default(cuid())
  taskId        String      @map("task_id")
  fromStatus    TaskStatus? @map("from_status")
  toStatus      TaskStatus  @map("to_status")
  actorId       String?     @map("actor_id")
  correlationId String?     @map("correlation_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor         User?       @relation(fields: [actorId], references: [id])

  @@index([taskId, createdAt])
  @@index([actorId])
  @@map("task_status_history")
}

model Deal {
  id              String    @id @default(cuid())
  title           String
  branchId        String    @map("branch_id")
  ownerId         String    @map("owner_id")
  currentHolderId String    @map("current_holder_id")
  stage           DealStage @default(LEAD)
  stageDueAt      DateTime  @map("stage_due_at")
  blocker         String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  branch          Branch    @relation(fields: [branchId], references: [id])
  owner           User      @relation("DealOwner", fields: [ownerId], references: [id])
  currentHolder   User      @relation("DealCurrentHolder", fields: [currentHolderId], references: [id])

  @@index([branchId, stage])
  @@index([ownerId])
  @@index([currentHolderId])
  @@index([stageDueAt])
  @@map("deals")
}

model Case {
  id                   String                   @id @default(cuid())
  type                 CaseType                 @default(CUSTOMER_COMPLAINT)
  status               ComplaintStatus          @default(DRAFT)
  lifecycleStatus      CaseLifecycleStatus      @default(DRAFT) @map("lifecycle_status")
  confidentialityLevel CaseConfidentialityLevel @default(NORMAL) @map("confidentiality_level")
  branchId             String                   @map("branch_id")
  ownerId              String?                  @map("owner_id")
  subject              String
  descriptionEn        String                   @map("description_en")
  descriptionAr        String?                  @map("description_ar")
  createdAt            DateTime                 @default(now()) @map("created_at")
  updatedAt            DateTime                 @updatedAt @map("updated_at")
  branch               Branch                   @relation(fields: [branchId], references: [id])
  owner                User?                    @relation("CaseOwner", fields: [ownerId], references: [id])
  links                CaseLink[]
  participants         CaseParticipant[]
  restrictedNotes      CaseRestrictedNote[]
  lifecycleHistory     CaseLifecycleHistory[]
  capaActions          CapaAction[]

  @@index([type, status])
  @@index([confidentialityLevel])
  @@index([branchId, status])
  @@index([ownerId])
  @@index([createdAt])
  @@map("cases")
}

model CaseLink {
  id         String             @id @default(cuid())
  caseId     String             @map("case_id")
  entityType CaseLinkEntityType @map("entity_type")
  entityId   String             @map("entity_id")
  createdAt  DateTime           @default(now()) @map("created_at")
  case       Case               @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([caseId, entityType, entityId])
  @@index([entityType, entityId])
  @@map("case_links")
}

model CaseParticipant {
  id        String              @id @default(cuid())
  caseId    String              @map("case_id")
  userId    String              @map("user_id")
  role      CaseParticipantRole @default(PARTICIPANT)
  createdAt DateTime            @default(now()) @map("created_at")
  case      Case                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id])

  @@unique([caseId, userId])
  @@index([userId])
  @@index([role])
  @@map("case_participants")
}

model CaseRestrictedNote {
  id        String   @id @default(cuid())
  caseId    String   @map("case_id")
  authorId  String?  @map("author_id")
  body      String
  createdAt DateTime @default(now()) @map("created_at")
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author    User?    @relation("CaseRestrictedNoteAuthor", fields: [authorId], references: [id])

  @@index([caseId, createdAt])
  @@index([authorId])
  @@map("case_restricted_notes")
}

model CaseLifecycleHistory {
  id            String               @id @default(cuid())
  caseId        String               @map("case_id")
  fromStatus    CaseLifecycleStatus? @map("from_status")
  toStatus      CaseLifecycleStatus  @map("to_status")
  actorId       String?              @map("actor_id")
  correlationId String?              @map("correlation_id")
  createdAt     DateTime             @default(now()) @map("created_at")
  case          Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId, createdAt])
  @@map("case_lifecycle_history")
}

model CapaAction {
  id                      String     @id @default(cuid())
  caseId                  String     @map("case_id")
  ownerId                 String     @map("owner_id")
  rootCause               String     @map("root_cause")
  responsibleDepartmentId String?    @map("responsible_department_id")
  correctiveAction        String     @map("corrective_action")
  preventiveAction        String     @map("preventive_action")
  dueAt                   DateTime   @map("due_at")
  status                  CapaActionStatus @default(OPEN)
  effectivenessCheck      String?    @map("effectiveness_check")
  repeatFlag              Boolean    @default(false) @map("repeat_flag")
  createdAt               DateTime   @default(now()) @map("created_at")
  updatedAt               DateTime   @updatedAt @map("updated_at")
  case                    Case       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  owner                   User       @relation("CapaActionOwner", fields: [ownerId], references: [id])
  responsibleDepartment   Department? @relation(fields: [responsibleDepartmentId], references: [id])

  @@index([caseId])
  @@index([ownerId])
  @@index([responsibleDepartmentId])
  @@index([dueAt])
  @@map("capa_actions")
}

model AuditLog {
  id            String         @id @default(cuid())
  eventType     AuditEventType  @map("event_type")
  action        String
  actorId       String?        @map("actor_id")
  branchId      String?        @map("branch_id")
  targetType    String         @map("target_type")
  targetId      String?        @map("target_id")
  correlationId String?        @map("correlation_id")
  ipAddress     String?        @map("ip_address")
  userAgent     String?        @map("user_agent")
  metadata      Json?
  createdAt     DateTime       @default(now()) @map("created_at")
  actor         User?          @relation("AuditActor", fields: [actorId], references: [id])
  branch        Branch?        @relation(fields: [branchId], references: [id])

  @@index([eventType, createdAt])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([correlationId])
  @@map("audit_logs")
}
