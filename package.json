{
  "name": "cms-auto",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsc -p apps/api/tsconfig.json && pnpm --filter @cms-auto/web build && tsc -p packages/database/tsconfig.json && tsc -p packages/contracts/tsconfig.json && tsc -p packages/config/tsconfig.json",
    "lint": "node tools/lint.mjs",
    "typecheck": "tsc -p apps/api/tsconfig.json --noEmit && tsc -p apps/web/tsconfig.json --noEmit && tsc -p packages/database/tsconfig.json --noEmit && tsc -p packages/database/prisma/tsconfig.json --noEmit && tsc -p packages/contracts/tsconfig.json --noEmit && tsc -p packages/config/tsconfig.json --noEmit",
    "generate:module": "node tools/generate-module.mjs",
    "db:seed": "prisma db seed --schema packages/database/prisma/schema.prisma",
    "prisma:validate": "node tools/prisma-validate.mjs",
    "test": "node --test --experimental-test-coverage --test-coverage-lines=80 --test-coverage-functions=75 --test-coverage-branches=65 tools/*.test.mjs",
    "test:api": "node tools/api-test.mjs",
    "test:e2e": "node tools/e2e-runner.mjs",
    "test:web": "node tools/web-test.mjs",
    "test:visual": "node --import tsx tools/web-proof.mjs visual",
    "web:visual-review": "node --import tsx tools/web-visual-review.mjs",
    "web:perf": "node --import tsx tools/web-proof.mjs perf",
    "test:performance": "node --import tsx tools/web-proof.mjs perf",
    "smtp:proof": "node --import tsx tools/smtp-arrival-proof.mjs",
    "prod:config:check": "node tools/prod-config-check.mjs",
    "openapi:generate": "node tools/openapi-check.mjs --write",
    "openapi:check": "node tools/openapi-check.mjs",
    "db:migrate:test": "node tools/pending-proof.mjs db:migrate:test",
    "db:index:check": "node tools/pending-proof.mjs db:index:check",
    "security:check": "node tools/security-check.mjs",
    "ops:backup:check": "node tools/ops-backup-check.mjs"
  },
  "prisma": {
    "seed": "tsx packages/database/prisma/seed.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@types/node": "^20.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.19.0",
    "typescript": "5.6.3"
  }
}
